generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  USER
}

enum BlogStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum LeadSource {
  CONTACT
  BOOKING
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  WON
  LOST
  ARCHIVED
}

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  password  String?
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  blogs Blog[]
}

model Blog {
  id              String     @id @default(cuid())
  title           String
  slug            String     @unique
  excerpt         String
  content         Json
  featuredImage   String?
  imageAlt        String?
  categoryId      String?
  category        Category?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  authorId        String?
  author          User?      @relation(fields: [authorId], references: [id], onDelete: SetNull)
  authorName      String     @default("Marcos Water Solutions")
  seoTitle        String?
  metaDescription String?
  keywords        String[]
  readTime        String?
  status          BlogStatus @default(DRAFT)
  publishedAt     DateTime?
  showOnHomepage  Boolean    @default(true)
  homepageOrder   Int?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  @@index([status, publishedAt])
  @@index([showOnHomepage, status, publishedAt])
  @@index([categoryId])
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  blogs     Blog[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Media {
  id        String   @id @default(cuid())
  url       String
  alt       String?
  mimeType  String?
  size      Int?
  createdAt DateTime @default(now())
}

model Review {
  id        String   @id @default(cuid())
  name      String
  location  String?
  rating    Int      @default(5)
  message   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
}

model Lead {
  id              String     @id @default(cuid())
  source          LeadSource
  status          LeadStatus @default(NEW)
  name            String
  phone           String
  email           String
  company         String?
  interest        String?
  productId       String?
  productName     String?
  requirementType String?
  preferredDate   String?
  preferredTime   String?
  location        String?
  message         String
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([source, createdAt])
  @@index([status, createdAt])
  @@index([email])
}
